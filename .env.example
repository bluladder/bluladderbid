# Copy to .env and fill with your project's values.
# All VITE_* vars are embedded in the browser bundle at build time —
# only put values that are safe to expose publicly.
# Server-side secrets (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, JOBBER_*,
# CALLRAIL_*, webhook signing secrets, etc.) are stored in Lovable/Supabase
# server-side secrets and MUST NOT be added to this file or .env.

# --- Frontend-public (safe to ship in browser bundle) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_META_PIXEL_ID=000000000000000

# --- Restricted browser credential (public but should be origin-locked at the provider) ---
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=your-browser-restricted-google-maps-key